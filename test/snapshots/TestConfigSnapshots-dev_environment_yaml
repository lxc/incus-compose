name: dev_environment
services:
  app:
    command:
      - npm
      - run
      - dev
    depends_on:
      db:
        condition: service_started
        required: true
    environment:
      NODE_ENV: development
    image: docker.io/library/node:20-alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 3000
        published: "3000"
        protocol: tcp
    volumes:
      - type: bind
        source: $FIXTURE_PATH/src
        target: /app
        bind: {}
      - type: volume
        source: node_modules
        target: /app/node_modules
        volume: {}
    working_dir: /app
  db:
    environment:
      POSTGRES_DB: devdb
      POSTGRES_PASSWORD: devpass
      POSTGRES_USER: devuser
    image: docker.io/library/postgres:16-alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 5432
        published: "5432"
        protocol: tcp
    volumes:
      - type: volume
        source: db_data
        target: /var/lib/postgresql/data
        volume: {}
networks:
  default:
    name: dev_environment_default
volumes:
  db_data:
    name: dev_environment_db_data
  node_modules:
    name: dev_environment_node_modules
