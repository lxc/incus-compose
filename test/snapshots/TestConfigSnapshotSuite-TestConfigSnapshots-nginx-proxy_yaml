name: nginx-proxy
services:
  backend1:
    environment:
      NGINX_WORKER_PROCESSES: "1"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://127.0.0.1:8080
      timeout: 5s
      interval: 10s
      retries: 3
    image: docker.io/nginxinc/nginx-unprivileged:alpine
    networks:
      backend: null
    restart: unless-stopped
  backend2:
    environment:
      NGINX_WORKER_PROCESSES: "1"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://127.0.0.1:8080
      timeout: 5s
      interval: 10s
      retries: 3
    image: docker.io/nginxinc/nginx-unprivileged:alpine
    networks:
      backend: null
    restart: unless-stopped
  nginx:
    depends_on:
      backend1:
        condition: service_healthy
        required: true
      backend2:
        condition: service_healthy
        required: true
    environment:
      NGINX_WORKER_PROCESSES: "1"
    healthcheck:
      test:
        - CMD
        - wget
        - -q
        - --spider
        - http://127.0.0.1:8080
      timeout: 5s
      interval: 10s
      retries: 3
    image: docker.io/nginxinc/nginx-unprivileged:alpine
    networks:
      backend: null
      frontend: null
    ports:
      - mode: ingress
        target: 8080
        published: "8080"
        protocol: tcp
    restart: unless-stopped
networks:
  backend:
    name: nginx-proxy_backend
    driver: bridge
    internal: true
  frontend:
    name: nginx-proxy_frontend
    driver: bridge
