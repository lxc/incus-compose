name: nginx-proxy
services:
  backend1:
    command:
      - python
      - -m
      - http.server
      - "8000"
    environment:
      SERVICE_NAME: backend1
    expose:
      - "8000"
    image: docker.io/library/python:3.11-slim
    networks:
      backend: null
  backend2:
    command:
      - python
      - -m
      - http.server
      - "8000"
    environment:
      SERVICE_NAME: backend2
    expose:
      - "8000"
    image: docker.io/library/python:3.11-slim
    networks:
      backend: null
  nginx:
    depends_on:
      backend1:
        condition: service_started
        required: true
      backend2:
        condition: service_started
        required: true
    image: docker.io/library/nginx:alpine
    networks:
      backend: null
      frontend: null
    ports:
      - mode: ingress
        target: 80
        published: "80"
        protocol: tcp
      - mode: ingress
        target: 443
        published: "443"
        protocol: tcp
    volumes:
      - type: bind
        source: $FIXTURE_PATH/nginx.conf
        target: /etc/nginx/nginx.conf
        read_only: true
        bind: {}
      - type: bind
        source: $FIXTURE_PATH/certs
        target: /etc/nginx/certs
        read_only: true
        bind: {}
networks:
  backend:
    name: nginx-proxy_backend
    driver: bridge
    internal: true
  frontend:
    name: nginx-proxy_frontend
    driver: bridge
