name: with-profiles
services:
  prometheus:
    profiles:
      - monitoring
      - prod
    image: docker.io/prom/prometheus:latest
    networks:
      default: null
    ports:
      - mode: ingress
        target: 9090
        published: "9090"
        protocol: tcp
  web:
    environment:
      NGINX_WORKER_PROCESSES: "1"
    image: docker.io/library/nginx:alpine
    networks:
      default: null
    ports:
      - mode: ingress
        target: 80
        published: "80"
        protocol: tcp
    volumes:
      - type: bind
        source: $FIXTURE_PATH/html
        target: /usr/share/nginx/html
        read_only: true
        bind: {}
networks:
  default:
    name: with-profiles_default
