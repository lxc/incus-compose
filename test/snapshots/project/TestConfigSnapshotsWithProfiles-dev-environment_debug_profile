name: dev-environment
services:
  app:
    command:
      - npm
      - run
      - dev
    depends_on:
      db:
        condition: service_started
        required: true
    environment:
      NODE_ENV: development
    image: docker.io/library/node:24-alpine
    networks:
      default: null
    volumes:
      - type: volume
        source: node_modules
        target: /app/node_modules
        volume: {}
    working_dir: /app
  db:
    environment:
      POSTGRES_DB: devdb
      POSTGRES_PASSWORD: devpass
      POSTGRES_USER: devuser
    image: docker.io/library/postgres:18-alpine
    networks:
      default: null
    volumes:
      - type: volume
        source: db_data
        target: /var/lib/postgresql/data
        volume: {}
  mailhog:
    profiles:
      - debug
      - mail
    image: docker.io/mailhog/mailhog:latest
    networks:
      default: null
  pgadmin:
    profiles:
      - debug
      - tools
    depends_on:
      db:
        condition: service_started
        required: true
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@local.dev
      PGADMIN_DEFAULT_PASSWORD: admin
    image: docker.io/dpage/pgadmin4:latest
    networks:
      default: null
networks:
  default:
    name: dev-environment_default
volumes:
  db_data:
    name: dev-environment_db_data
  node_modules:
    name: dev-environment_node_modules
