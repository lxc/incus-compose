name: with-profiles
services:
  adminer:
    profiles:
      - debug
      - dev
    image: docker.io/library/adminer:latest
    networks:
      default: null
  hot-reload:
    profiles:
      - dev
    command:
      - npm
      - run
      - hot-reload
    image: docker.io/library/node:20-alpine
    networks:
      default: null
  prometheus:
    profiles:
      - monitoring
      - prod
    image: docker.io/prom/prometheus:latest
    networks:
      default: null
  web:
    environment:
      NGINX_ENTRYPOINT_WORKER_PROCESSES_AUTOTUNE: "1"
    image: docker.io/library/nginx:alpine
    networks:
      default: null
    volumes:
      - type: bind
        source: $FIXTURE_PATH/html
        target: /usr/share/nginx/html
        read_only: true
        bind: {}
    x-incus:
      limits.cpu: 1
  webpack:
    profiles:
      - dev
    command:
      - npm
      - run
      - watch
    image: docker.io/library/node:20-alpine
    networks:
      default: null
    volumes:
      - type: bind
        source: $FIXTURE_PATH/src
        target: /app/src
        bind: {}
      - type: bind
        source: $FIXTURE_PATH/dist
        target: /app/dist
        bind: {}
    working_dir: /app
networks:
  default:
    name: with-profiles_default
