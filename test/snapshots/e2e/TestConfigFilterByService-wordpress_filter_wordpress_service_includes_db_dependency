project:
  name: test-local-config-filter
  services:
    db:
      environment:
        MYSQL_DATABASE: wordpress
        MYSQL_PASSWORD: wordpress
        MYSQL_ROOT_PASSWORD: somewordpress
        MYSQL_USER: wordpress
      image: docker.io/library/mysql:9.5.0
      networks:
        default: null
      restart: always
      volumes:
        - type: volume
          source: db_data
          target: /var/lib/mysql
          volume: {}
    wordpress:
      depends_on:
        db:
          condition: service_started
          required: true
      environment:
        WORDPRESS_DB_HOST: db:3306
        WORDPRESS_DB_NAME: wordpress
        WORDPRESS_DB_PASSWORD: wordpress
        WORDPRESS_DB_USER: wordpress
      image: docker.io/library/wordpress:6.9.0-php8.1-apache
      networks:
        default: null
      restart: always
      volumes:
        - type: volume
          source: wordpress_data
          target: /var/www/html
          volume: {}
  networks:
    default:
      name: test-local-config-filter_default
  volumes:
    db_data:
      name: test-local-config-filter_db_data
    wordpress_data:
      name: test-local-config-filter_wordpress_data
