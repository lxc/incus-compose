project:
  name: test-local-config
  services:
    always-restart:
      image: docker.io/library/alpine:latest
      networks:
        default: null
      restart: always
    default-restart:
      image: docker.io/library/alpine:latest
      networks:
        default: null
    no-restart:
      image: docker.io/library/alpine:latest
      networks:
        default: null
      restart: "no"
    on-failure-restart:
      image: docker.io/library/alpine:latest
      networks:
        default: null
      restart: on-failure
    unless-stopped-restart:
      image: docker.io/library/alpine:latest
      networks:
        default: null
      restart: unless-stopped
  networks:
    default:
      name: test-local-config_default
